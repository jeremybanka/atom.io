{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"automerge": true,
	"branchConcurrentLimit": 9,
	"internalChecksFilter": "strict",
	"minimumReleaseAge": "1 day",
	"postUpdateOptions": ["pnpmDedupe"],
	"prConcurrentLimit": 3,
	"prHourlyLimit": 9,
	"pruneBranchAfterAutomerge": true,
	"pruneStaleBranches": true,
	"statusCheckWhen": { "minimumReleaseAge": "never" },
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["/^\\.github\\/actions\\/setup\\/action\\.yml$/"],
			"matchStrings": [
				"uses: jdx\\/mise-action@\\S+(?:\\s+#.*)?\\s+      with:\\s+        version: (?<currentValue>\\S+)"
			],
			"depNameTemplate": "jdx/mise",
			"datasourceTemplate": "github-releases",
			"versioningTemplate": "semver-coerced"
		}
	],
	"packageRules": [
		{
			"matchPackageNames": [
				"break-check",
				"comline",
				"lasertag",
				"recoverage",
				"takua",
				"treetrunks"
			],
			"minimumReleaseAge": null
		},
		{
			"matchManagers": ["github-actions"],
			"dependencyDashboardApproval": true
		},
		{
			"matchDepNames": ["jdx/mise"],
			"dependencyDashboardApproval": true
		},
		{
			"matchPackageNames": ["tsdown", "@tsdown/css"],
			"groupName": "tsdown"
		},
		{
			"matchPackageNames": ["eslint-plugin-astro", "astro-eslint-parser"],
			"groupName": "astro eslint"
		}
	]
}
