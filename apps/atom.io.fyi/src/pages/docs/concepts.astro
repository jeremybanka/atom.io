---
import Layout from "../../layouts/LayoutDocs.astro"
import css from "./concepts.module.css"

type ConceptModule = {
	Content: () => unknown
	frontmatter: {
		packages?: string[]
		related?: string[]
		slug: string
		summary: string
		title: string
	}
}

const conceptModules = import.meta.glob<ConceptModule>(
	"../../../../../packages/atom.io/docs/source/concepts/*.md",
	{ eager: true },
)
const concepts = Object.values(conceptModules)
	.map((concept) => ({
		Content: concept.Content,
		frontmatter: concept.frontmatter,
	}))
	.sort((a, b) => a.frontmatter.title.localeCompare(b.frontmatter.title))
const conceptLabelBySlug = new Map(
	concepts.map(({ frontmatter }) => [
		frontmatter.slug,
		frontmatter.title.toLowerCase(),
	]),
)
---

<Layout>
	<h1>concepts</h1>
	<p>
		A field guide to the main atom.io ideas: what each concept means, where it
		appears, and which nearby concepts to learn next.
	</p>
	<concepts-glossary class={css.class}>
		{concepts.map(({ Content, frontmatter }) => (
			<concept-module aria-labelledby={frontmatter.slug}>
				<header>
					<h2 id={frontmatter.slug}>{frontmatter.title.toLowerCase()}</h2>
					<p>
						<span>{frontmatter.summary}</span>
					</p>
				</header>
				<main>
					<concept-metadata aria-label={`${frontmatter.title} metadata`}>
						<section>
							<h3>packages</h3>
							<ul>
								{(frontmatter.packages ?? ["atom.io"]).map((packageName) => (
									<li>
										<package-name>{packageName}</package-name>
									</li>
								))}
							</ul>
						</section>
						{frontmatter.related && frontmatter.related.length > 0 && (
							<section>
								<h3>related</h3>
								<ul>
									{frontmatter.related.map((slug) => (
										<li>
											<a href={`#${slug}`}>
												{conceptLabelBySlug.get(slug) ?? slug}
											</a>
										</li>
									))}
								</ul>
							</section>
						)}
					</concept-metadata>
					<Content />
				</main>
			</concept-module>
		))}
	</concepts-glossary>
</Layout>
