---
import Layout from "../layouts/Layout.astro"
import packageJson from "atom.io/package.json"
import css from "./index.module.css"
---

<Layout>
	<home-splash class={css.class}>
		<title-lockup>
			<h1>
				<span>atom</span>
				<span>.io</span>
			</h1>
			<npm-description>
				{packageJson.description}
			</npm-description>
			<cta-links>
				<a href="/docs/getting-started">
					Get Started
				</a>
				<a href="/docs">
					Read the Docs
				</a>
			</cta-links>
		</title-lockup>
	</home-splash>
</Layout>
