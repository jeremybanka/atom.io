{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"paths": {
			"c/*": ["./src/components/*"],
			"x/*": ["./src/exhibits-wrapped/*"]
		},
		"types": [
			"lasertag/css-modules",
			"lasertag/preact-jsx"
		]
	}
}
