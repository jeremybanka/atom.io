{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"globalDependencies": ["tsconfig.json", ".node-version"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "bin/**"],
			"inputs": [
				"package.json",
				"tsconfig.json",
				"*.config.ts",
				"src/**",
				"__scripts__/**"
			]
		},
		"manifest:test": {
			"dependsOn": [],
			"outputs": [],
			"inputs": [
				"**/*.{ts,tsx}"
			]
		},
		"test:once": {
			"dependsOn": ["build"],
			"inputs": [
				"package.json",
				"tsconfig.json",
				"*.config.ts",
				"src/**",
				"__tests__/**",
				"__scripts__/**"
			]
		},
		"cov": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"],
			"inputs": [
				"tsconfig.json",
				"package.json",
				"*.config.ts",
				"src/**",
				"__tests__/**",
				"__scripts__/**"
			]
		},
		"cov:recoverage": {
			"dependsOn": ["cov"],
			"cache": false,
			"passThroughEnv": ["RECOVERAGE_CLOUD_TOKEN"]
		},
		"cov:public": {
			"dependsOn": ["^build"],
			"outputs": ["coverage-public/**"],
			"inputs": [
				"tsconfig.json",
				"package.json",
				"*.config.ts",
				"src/**",
				"__tests__/**",
				"__scripts__/**"
			]
		},
		"test:breaks": {
			"dependsOn": ["^build"],
			"inputs": [
				"../../.changeset/**",
				"package.json",
				"tsconfig.json",
				"break-check.config.json",
				"*.config.ts",
				"src/**",
				"__tests__/public/**",
				"__scripts__/**"
			]
		},
		"lint:eslint": {
			"dependsOn": ["^build", "atom.io#build"],
			"inputs": [
				"../../package.json",
				"../../eslint.config.ts",
				"**/package.json",
				"tsconfig.json",
				"src/**",
				"__tests__/**",
				"__scripts__/**"
			]
		},
		"lint:oxlint": {
			"dependsOn": ["^build"],
			"inputs": [
				"../../package.json",
				"../../oxlint.config.ts",
				"package.json",
				"tsconfig.json",
				"src/**",
				"__tests__/**",
				"__scripts__/**",
				"**/*.d.ts"
			]
		},
		"lint:types": {
			"dependsOn": ["^build"],
			"inputs": [
				"../../package.json",
				"package.json",
				"tsconfig.json",
				"src/**",
				"__tests__/**",
				"__scripts__/**",
				"**/*.d.ts"
			]
		},
		"lint": {
			"dependsOn": ["lint:eslint", "lint:oxlint", "lint:types"]
		}
	}
}
