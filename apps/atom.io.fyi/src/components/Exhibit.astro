---
import { exhibits } from "virtual:atom-io-exhibits"

import {
	extractExhibitCode,
	normalizeExhibitSource,
	parseExhibitReference,
} from "@atom.io/exhibits"
import { CodeBlock } from "./CodeBlock"

type Props = {
	label?: string
	soft?: boolean
	src: string
}

function getDisplayFilename(src: string): string {
	const filename = src.split(`/`).pop() ?? `code`
	return filename.endsWith(`.txt`) ? filename.slice(0, -`.txt`.length) : filename
}

const { label, soft = false, src } = Astro.props
const reference = parseExhibitReference(src)
const normalizedSource = normalizeExhibitSource(reference.source)
const sourceCode = exhibits[normalizedSource]

if (sourceCode === undefined) {
	throw new Error(`Unknown exhibit source: ${src}`)
}

const code = extractExhibitCode(sourceCode, reference)
const filepath = getDisplayFilename(normalizedSource)
---

<CodeBlock code={code} filepath={filepath} label={label} soft={soft} />
