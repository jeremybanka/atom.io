{
	"name": "@atom.io/monorepo",
	"version": "0.0.0",
	"type": "module",
	"repository": "https://github.com/jeremybanka/atom.io",
	"author": "jeremybanka",
	"license": "GPL-3.0",
	"private": true,
	"packageManager": "pnpm@11.7.0",
	"engines": {
		"node": "26.3.0"
	},
	"workspaces": [
		"apps/*",
		"packages/*",
		"templates/*"
	],
	"scripts": {
		"gen": "dotenvx run -- turbo run gen",
		"lint": "dotenvx run -- turbo run lint",
		"lint:deps": "pin-checker --ignore-workspaces",
		"lint:eslint": "dotenvx run -- turbo run lint:eslint",
		"lint:oxlint": "dotenvx run -- turbo run lint:oxlint",
		"lint:types": "dotenvx run -- turbo run lint:types",
		"watch:types": "dotenvx run -- turbo run watch:types --concurrency=30",
		"lint:fix:eslint": "eslint --fix .",
		"fmt": "dprint fmt .",
		"fmt:check": "dprint check .",
		"hooks:install": "mise x -- hk install --mise",
		"build": "dotenvx run -- turbo run build",
		"test": "CI=true dotenvx run -- turbo run test:once --concurrency=2",
		"test:coverage:increased": "CI=true turbo run test:coverage:increased",
		"test:semver": "CI=true dotenvx run -- turbo run test:semver",
		"release": "bun run build && changeset publish",
		"notes": "changeset",
		"vigilance": "bun scripts/vigilance-bot.bun.ts",
		"nuke": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' + && rm pnpm-lock.yaml",
		"nv": "fnm use $(pnpm list -w --json | jq -r '.[0].path')",
		"version": "dotenvx run -- turbo run version",
		"upgrade-workflows": "bun scripts/update-workflows.bun.ts"
	},
	"devDependencies": {
		"@changesets/cli": "2.31.0",
		"@changesets/config": "3.1.4",
		"@dotenvx/dotenvx": "1.72.0",
		"@dprint/json": "0.21.3",
		"@dprint/markdown": "0.22.1",
		"@dprint/oxc": "0.26.0",
		"@dprint/toml": "0.7.0",
		"@typescript-eslint/eslint-plugin": "8.61.1",
		"@typescript-eslint/parser": "8.61.1",
		"@typescript-eslint/utils": "8.61.1",
		"@typescript/native-preview": "7.0.0-dev.20260616.1",
		"astro-eslint-parser": "1.4.0",
		"dprint": "0.54.0",
		"dprint-plugin-malva": "0.16.0",
		"dprint-plugin-markup": "0.27.3",
		"dprint-plugin-yaml": "0.6.0",
		"eslint": "10.5.0",
		"eslint-plugin-astro": "1.7.0",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"eslint-plugin-storybook": "10.4.5",
		"jiti": "2.7.0",
		"lasertag": "0.1.5",
		"oxlint": "1.70.0",
		"oxlint-tsgolint": "0.23.0",
		"pin-dependencies-checker": "2.7.1",
		"turbo": "2.9.18",
		"typescript": "6.0.3",
		"vitest": "4.1.9"
	}
}
