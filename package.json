{
	"name": "@atom.io/monorepo",
	"version": "0.0.0",
	"type": "module",
	"repository": "https://github.com/jeremybanka/atom.io",
	"author": "jeremybanka",
	"license": "GPL-3.0",
	"private": true,
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": "26.4.0"
	},
	"workspaces": [
		"apps/*",
		"packages/*",
		"templates/*"
	],
	"scripts": {
		"build": "dotenvx run -- turbo run build",
		"cov:public": "dotenvx run -- turbo run cov:public",
		"cov:recoverage": "dotenvx run -- turbo run cov:recoverage",
		"dev": "dotenvx run -- turbo run dev",
		"fmt": "dprint fmt .",
		"fmt:check": "dprint check .",
		"hooks:install": "mise x -- hk install --mise",
		"lint": "dotenvx run -- turbo run lint",
		"lint:deps": "pin-checker --ignore-workspaces",
		"lint:eslint": "dotenvx run -- turbo run lint:eslint",
		"lint:fix:eslint": "eslint --fix .",
		"lint:oxlint": "dotenvx run -- turbo run lint:oxlint",
		"lint:types": "dotenvx run -- turbo run lint:types",
		"manifest:test": "dotenvx run -- turbo run manifest:test",
		"changes": "changeset",
		"changes:publish": "bun run build && changeset publish",
		"changes:version": "changeset version && bun run fmt",
		"test": "CI=true dotenvx run -- turbo run test:once --concurrency=2",
		"test:breaks": "CI=true dotenvx run -- turbo run test:breaks",
		"vigilance": "bun scripts/vigilance-bot.bun.ts",
		"workflows": "bun scripts/update-workflows.bun.ts"
	},
	"devDependencies": {
		"@changesets/cli": "2.31.0",
		"@changesets/config": "3.1.4",
		"@dotenvx/dotenvx": "1.75.1",
		"@dprint/json": "0.21.3",
		"@dprint/markdown": "0.22.1",
		"@dprint/oxc": "0.28.0",
		"@dprint/toml": "0.7.0",
		"@typescript-eslint/eslint-plugin": "8.62.0",
		"@typescript-eslint/parser": "8.62.0",
		"@typescript-eslint/utils": "8.62.0",
		"@typescript/native-preview": "7.0.0-dev.20260628.1",
		"astro-eslint-parser": "2.1.0",
		"dprint": "0.54.0",
		"dprint-plugin-malva": "0.16.0",
		"dprint-plugin-markup": "0.27.3",
		"dprint-plugin-yaml": "0.6.0",
		"eslint": "10.6.0",
		"eslint-plugin-astro": "2.1.1",
		"eslint-plugin-import-x": "4.17.0",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"eslint-plugin-storybook": "10.4.6",
		"jiti": "2.7.0",
		"lasertag": "0.1.5",
		"oxlint": "1.71.0",
		"oxlint-tsgolint": "0.23.0",
		"pin-dependencies-checker": "2.7.1",
		"turbo": "2.10.0",
		"typescript": "6.0.3",
		"vitest": "4.1.9"
	}
}
